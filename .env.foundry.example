# Claude（Azure AI Foundry）で生成する場合の .env テンプレート
# これを .env にコピーし、<...> を実際の値に置き換える。
# 検索・埋め込みは docs/zero-cost.md 側の設定（ローカル検索 + OpenAI互換埋め込み）を併用。

# --- チャット生成: Claude on Foundry ---
CHAT_BACKEND=foundry
ANTHROPIC_FOUNDRY_RESOURCE=<Foundryリソース名>       # 例: example-resource
CHAT_DEPLOYMENT=claude-opus-4-8                       # Foundryのデプロイ名（既定はモデルID）

# 認証はどちらか一方
# A) APIキー（手軽・プロトタイプ向き）
ANTHROPIC_FOUNDRY_API_KEY=<FoundryのKey>
# B) Entra ID（キーレス・本番推奨。要 azure-identity と RBAC ロール）
# FOUNDRY_AUTH=entra

# --- 埋め込み（クエリのベクトル化）。インデックス構築時と同じ設定にすること ---
EMBED_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/
EMBED_API_KEY=<Google AI Studio のキー>
EMBED_DEPLOYMENT=gemini-embedding-001
EMBED_DIMENSIONS=1536

# 検索は corpus/ があれば自動でローカル（VECTOR_BACKEND=auto 既定）
